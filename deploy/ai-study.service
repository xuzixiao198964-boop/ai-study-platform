[Unit]
Description=学习指认AI平台 - FastAPI 后端服务
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=aistudy
Group=aistudy
WorkingDirectory=/opt/ai-study-platform
Environment=PATH=/opt/ai-study-platform/venv/bin:/usr/bin
ExecStart=/opt/ai-study-platform/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001 --workers 4
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
